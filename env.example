# Copy to .env and fill in. NEVER commit the real .env.

# MongoDB connection string
DB_URI=mongodb+srv://user:pass@cluster/dbname

# Strong random secret for signing JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-long-random-value

# Allowed frontend origin(s), comma-separated. Example:
CLIENT_ORIGIN=http://localhost:5173,https://pass-manger-client.vercel.app

# Optional, defaults to 5500
PORT=5500
